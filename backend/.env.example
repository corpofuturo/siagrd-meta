# ── Obligatorias — el servidor no arranca sin estas ────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/siagrd
JWT_SECRET=cambia-esto-por-un-secreto-seguro-de-al-menos-32-caracteres

# ── Servidor ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Firebase (notificaciones push FCM) ─────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
# Alternativa: JSON completo de service account (base64 o string)
FIREBASE_SERVICE_ACCOUNT_JSON=

# ── VAPID (notificaciones web push) ────────────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=correo@ejemplo.com

# ── Almacenamiento de archivos ──────────────────────────────────────────────────
UPLOADS_DIR=./uploads

# ── Sentry (monitoreo de errores) ──────────────────────────────────────────────
SENTRY_DSN=
