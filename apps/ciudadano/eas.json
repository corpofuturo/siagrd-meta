{
  "cli": {
    "version": ">= 10.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://backend-production-60016.up.railway.app/api/v1"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://backend-production-60016.up.railway.app/api/v1"
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://backend-production-60016.up.railway.app/api/v1"
      }
    }
  }
}
