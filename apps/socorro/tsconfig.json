{
    "extends": "expo/tsconfig.base",
    "compilerOptions": {
          "strict": true,
          "experimentalDecorators": true,
          "emitDecoratorMetadata": true,
          "baseUrl": ".",
          "paths": {
                  "@siagrd/ui": ["../../packages/ui/src/index.ts"],
                  "@siagrd/ui/*": ["../../packages/ui/src/*"],
                  "@/*": ["./src/*"]
          }
    },
    "include": ["src", "*.ts", "*.tsx"],
    "exclude": ["node_modules"]
}
