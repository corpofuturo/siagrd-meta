{
  "name": "siagrd-meta",
  "version": "1.0.0",
  "private": true,
  "description": "Sistema Integrado de Alertas Tempranas y Gestión del Riesgo — Departamento del Meta, Colombia",
  "license": "MIT",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter backend dev",
    "build:backend": "pnpm --filter backend build",
    "build:panel-web": "pnpm --filter panel-web build",
    "build:ciudadano": "pnpm --filter ciudadano build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:backend": "pnpm --filter backend test",
    "test:ui": "pnpm --filter @siagrd/ui test",
    "test:e2e": "pnpm --filter panel-web exec playwright test",
    "db:migrate": "pnpm --filter backend db:migrate",
    "db:seed": "psql $DATABASE_URL -f database/seeds/municipios_meta.sql && psql $DATABASE_URL -f database/seeds/organismos_meta.sql",
    "ci": "pnpm lint && pnpm typecheck && pnpm test",
    "knip": "knip"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "backend"
  ],
  "pnpm": {
    "overrides": {
      "expo-linking": "6.3.1",
      "react": "18.2.0",
      "react-native": "0.73.6"
    }
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.0.0",
    "knip": "^6.24.0",
    "prettier": "^3.0.0",
    "typescript": "^5.4.0"
  }
}
