# ─── SUPABASE ─────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key  # NUNCA en cliente

# ─── APPS MÓVILES (prefijo EXPO_PUBLIC_ = expuesto en bundle) ─
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key

# ─── FIREBASE FCM ─────────────────────────────────────────
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ─── WEB PUSH (VAPID) ─────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:admin@siagrd.meta.gov.co

# ─── DEPLOY ───────────────────────────────────────────────
RAILWAY_TOKEN=your-railway-token
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_PROJECT_ID=your-vercel-project-id

# ─── MONITOREO ────────────────────────────────────────────
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id

# ─── SERVIDOR ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
